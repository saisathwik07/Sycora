PORT=3000

# MongoDB - provide MONGODB_URI for a full connection string, or use individual vars
MONGODB_URI=

# If Atlas auth still fails and your user uses a non-default auth DB (rare):
# MONGODB_AUTH_SOURCE=admin

# Local dev without Atlas (ephemeral DB): npm run dev:memory
# USE_IN_MEMORY_MONGO=true

# If Atlas `mongodb+srv` fails with querySrv ECONNREFUSED, try public DNS (optional):
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_USER=your_mongodb_user
MONGODB_PASSWORD=your_mongodb_password
MONGODB_DBNAME=your_mongodb_dbname
MONGODB_HOST=cluster0.example.mongodb.net

# JWT Secret Key - MUST be set to a strong random value
JWT_SECRET=your_secret_key

# Email (SMTP) - for password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SERVICE=gmail
SMTP_MAIL=your_email@gmail.com
SMTP_APP_PASS=your_app_password

# Frontend URL - used in password reset email links
FRONTEND_URL=http://localhost:4200

# Google OAuth (optional — enables “Continue with Google”)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Authorized redirect URI in Google Cloud Console, e.g. http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=

# CORS - comma-separated origins, or * for all (development only)
CORS_ORIGIN=http://localhost:4200
